REM STARRY NIGHT PROGRAM
GR
REM SET TO FULL-SCREEN GRAPHICS
POKE -16302,0
REM CLEAR BOTTOM OF SCREEN
COLOR=0: FOR I=40 TO 47: HLIN 0,39 AT I: NEXT I
REM PLOT STARS AND SPACES
<MAINLOOP> COLOR=INT(RND(1)*15)+1
PLOT INT(RND(1)*40), INT(RND(1)*40)
COLOR=0
FOR I=1 to 60
  PLOT INT(RND(1)*40), INT(RND(1)*47)
  NEXT I
GOTO @MAINLOOP
