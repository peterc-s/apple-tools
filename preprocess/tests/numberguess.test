# RUN: uv run preprocess ../examples/numberguess.bas | filecheck %s

# CHECK: 0 PRINT "NUMBER GUESSING GAME"
# CHECK-NEXT: 1 PRINT "I am thinking of a number from 1 to 10"
# CHECK-NEXT: 2 N = INT(RND(1)*10)+1
# CHECK-NEXT: 3 PRINT
# CHECK-NEXT: 4 PRINT "Guess the number."
# CHECK-NEXT: 5 INPUT "Your guess: ";G
# CHECK-NEXT: 6 W = 0
# CHECK-NEXT: 7 GOSUB 10
# CHECK-NEXT: 8 IF W = 1 THEN 20
# CHECK-NEXT: 9 GOTO 5
# CHECK-NEXT: 10 IF G = N THEN 14
# CHECK-NEXT: 11 IF G < N THEN 16
# CHECK-NEXT: 12 IF G > N THEN 18
# CHECK-NEXT: 13 RETURN
# CHECK-NEXT: 14 W = 1
# CHECK-NEXT: 15 RETURN
# CHECK-NEXT: 16 PRINT "TOO LOW"
# CHECK-NEXT: 17 RETURN
# CHECK-NEXT: 18 PRINT "TOO HIGH"
# CHECK-NEXT: 19 RETURN
# CHECK-NEXT: 20 PRINT "CORRECT!"
# CHECK-NEXT: 21 INPUT "Play again? (1=yes, 2=no): ";A
# CHECK-NEXT: 22 ON A GOTO 2,24
# CHECK-NEXT: 23 GOTO 21
# CHECK-NEXT: 24 PRINT "Goodbye!"
# CHECK-NEXT: 25 END
# CHECK-NOT: REM
