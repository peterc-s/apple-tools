# RUN: uv run preprocess ../examples/starrynight.bas | FileCheck %s

#CHECK: 0 GR
#CHECK-NEXT: 1 POKE -16302,0
#CHECK-NEXT: 2 COLOR=0: FOR I=40 TO 47: HLIN 0,39 AT I: NEXT I
#CHECK-NEXT: 3 COLOR=INT(RND(1)*15)+1
#CHECK-NEXT: 4 PLOT INT(RND(1)*40), INT(RND(1)*40)
#CHECK-NEXT: 5 COLOR=0
#CHECK-NEXT: 6 FOR I=1 TO 60
#CHECK-NEXT: 7 PLOT INT(RND(1)*40), INT(RND(1)*47)
#CHECK-NEXT: 8 NEXT I
#CHECK-NEXT: 9 GOTO 3
