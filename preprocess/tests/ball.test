# RUN: uv run preprocess ../examples/ball.bas | FileCheck %s

#CHECK: 0 BALL=9
#CHECK-NEXT: 1 GR
#CHECK-NEXT: 2 XOLD=20
#CHECK-NEXT: 3 XSPEED=1
#CHECK-NEXT: 4 XNEW=XOLD+XSPEED
#CHECK-NEXT: 5 IF (XNEW>-1) AND (XNEW<40) THEN GOTO 8
#CHECK-NEXT: 6 XSPEED=-1*XSPEED
#CHECK-NEXT: 7 GOTO 4
#CHECK-NEXT: 8 COLOR=BALL
#CHECK-NEXT: 9 PLOT XNEW,20
#CHECK-NEXT: 10 COLOR=0
#CHECK-NEXT: 11 PLOT XOLD,20
#CHECK-NEXT: 12 XOLD=XNEW
#CHECK-NEXT: 13 GOTO 4
